# Required: Neon PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"

# Required: Admin dashboard password for /admin
ADMIN_PASSWORD="change-this-strong-password"

# Required/recommended: Random long secret for admin login token signing
AUTH_SECRET="change-this-to-a-long-random-secret"

# Optional: Resend email notifications
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxx"
LEAD_NOTIFY_TO="official.athoo@gmail.com"
LEAD_EMAIL_FROM="Athoo Website <onboarding@resend.dev>"

# Optional rate limit
RATE_LIMIT_PER_MINUTE="10"
