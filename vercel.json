{
  "framework": "vite",
  "installCommand": "pnpm install --frozen-lockfile=false",
  "buildCommand": "pnpm run build:web",
  "outputDirectory": "artifacts/athoo/dist/public",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/[...path]" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
