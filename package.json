{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev:web": "pnpm --filter @workspace/athoo run dev",
    "dev:api": "pnpm --filter @workspace/api-server run dev",
    "build": "pnpm run typecheck && pnpm run build:api && pnpm run build:web",
    "build:web": "pnpm --filter @workspace/athoo run build",
    "build:api": "pnpm --filter @workspace/api-server run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm --filter @workspace/api-server run typecheck && pnpm --filter @workspace/athoo run typecheck",
    "start:api": "pnpm --filter @workspace/api-server run start",
    "db:schema": "pnpm --filter @workspace/api-server run db:schema"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "~5.9.3",
    "@vercel/node": "^5.5.6",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.5"
  },
  "packageManager": "pnpm@10.33.3",
  "dependencies": {
    "pg": "^8.16.3",
    "resend": "^6.12.4"
  }
}